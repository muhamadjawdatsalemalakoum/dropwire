# Copy to `relay/.env` (and keep it secret — never commit the real value).
#
# Long random secret that locks your relay to the Dropwire app build. The SAME
# value must be embedded in the app (CoreConfig::Infra::SelfHosted.relay_token).
# Generate one with:   openssl rand -hex 32
IROH_RELAY_ACCESS_TOKEN=replace_with_64_random_hex_chars
